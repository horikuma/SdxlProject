{
  "manifest_version": 3,
  "name": "Mid-Journey Clipper",
  "version": "1.0",
  "permissions": ["tabs", "notifications", "scripting", "contextMenus"],
  "host_permissions": [
    "https://www.midjourney.com/*",
    "http://localhost:41595/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "content_scripts": [
    {
      "matches": ["https://www.midjourney.com/*"],
      "js": ["content.js"]
    }
  ]
}